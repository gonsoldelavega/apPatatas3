# Copiar como .env en el entorno local o servidor aislado. No subir secretos reales.
POSTGRES_DB=factupapa_next
POSTGRES_USER=factupapa
POSTGRES_PASSWORD=CAMBIAR_CON_UNA_CLAVE_LARGA
POSTGRES_PORT=5432
API_DATABASE_USER=factupapa_api
API_DATABASE_PASSWORD=CAMBIAR_CON_UNA_CLAVE_DISTINTA

REDIS_PASSWORD=CAMBIAR_CON_UNA_CLAVE_LARGA
REDIS_PORT=6379

MINIO_ROOT_USER=factupapa_storage
MINIO_ROOT_PASSWORD=CAMBIAR_CON_UNA_CLAVE_LARGA
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

DATABASE_ADMIN_URL=postgresql://factupapa:CAMBIAR_CON_UNA_CLAVE_LARGA@postgres:5432/factupapa_next
DATABASE_URL=postgresql://factupapa_api:CAMBIAR_CON_UNA_CLAVE_DISTINTA@postgres:5432/factupapa_next
REDIS_URL=redis://:CAMBIAR_CON_UNA_CLAVE_LARGA@redis:6379
S3_ENDPOINT=http://minio:9000
S3_BUCKET=factupapa-documents
S3_ACCESS_KEY=factupapa_storage
S3_SECRET_KEY=CAMBIAR_CON_UNA_CLAVE_LARGA

APP_ENV=development
APP_PORT=4100
APP_VERSION=local
APP_BASE_URL=http://localhost:4100
CORS_ALLOWED_ORIGINS=http://127.0.0.1:4173
WEB_PORT=4173
WEB_API_BASE_URL=http://127.0.0.1:4100
JWT_SECRET=CAMBIAR_POR_AL_MENOS_64_CARACTERES
ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_DAYS=30
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_NAME=factupapa_refresh
LOGIN_RATE_LIMIT_MAX=5
LOGIN_RATE_LIMIT_WINDOW_MS=60000
IMPORT_MAX_BYTES=1048576
IMPORT_MAX_ROWS=1000
IMPORT_PREVIEW_ROWS=50
